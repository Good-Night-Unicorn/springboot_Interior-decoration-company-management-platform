<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.ZhuangxiudingdanDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.entity.ZhuangxiudingdanEntity" id="zhuangxiudingdanMap">
        <result property="dingdanbianhao" column="dingdanbianhao"/>
        <result property="zhuangxiubiaoti" column="zhuangxiubiaoti"/>
        <result property="zhuangxiuyaoqiu" column="zhuangxiuyaoqiu"/>
        <result property="zhuangxiushijian" column="zhuangxiushijian"/>
        <result property="zhuangxiushizhang" column="zhuangxiushizhang"/>
        <result property="dingdanjine" column="dingdanjine"/>
        <result property="dingdanxiangqing" column="dingdanxiangqing"/>
        <result property="kehuxinxi" column="kehuxinxi"/>
        <result property="dingdanzhuangtai" column="dingdanzhuangtai"/>
        <result property="yuangongzhanghao" column="yuangongzhanghao"/>
        <result property="yuangongxingming" column="yuangongxingming"/>
    </resultMap>

	<select id="selectListVO"
		resultType="com.entity.vo.ZhuangxiudingdanVO" >
		SELECT * FROM zhuangxiudingdan  zhuangxiudingdan         
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectVO"
		resultType="com.entity.vo.ZhuangxiudingdanVO" >
		SELECT  zhuangxiudingdan.* FROM zhuangxiudingdan  zhuangxiudingdan 	
 		<where> 1=1 ${ew.sqlSegment}</where>
	</select>

    <select id="selectListView"
		resultType="com.entity.view.ZhuangxiudingdanView" >

		SELECT  zhuangxiudingdan.* FROM zhuangxiudingdan  zhuangxiudingdan 	        
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.entity.view.ZhuangxiudingdanView" >
		SELECT * FROM zhuangxiudingdan  zhuangxiudingdan <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	

    <select id="selectValue" resultType="map" >
        SELECT ${params.xColumn}, ROUND(sum(${params.yColumn}),1) total FROM zhuangxiudingdan
        <where> 1=1 ${ew.sqlSegment}</where>
        group by ${params.xColumn}
    </select>

    <select id="selectTimeStatValue" resultType="map" >
        <if test = 'params.timeStatType == "日"'>
                SELECT DATE_FORMAT(${params.xColumn},'%Y-%m-%d') ${params.xColumn}, sum(${params.yColumn}) total FROM zhuangxiudingdan
                <where> 1=1 ${ew.sqlSegment}</where>
                group by DATE_FORMAT(${params.xColumn},'%Y-%m-%d')
        </if>
        <if test = 'params.timeStatType == "月"'>
                SELECT DATE_FORMAT(${params.xColumn},'%Y-%m') ${params.xColumn}, sum(${params.yColumn}) total FROM zhuangxiudingdan
                <where> 1=1 ${ew.sqlSegment}</where>
                group by DATE_FORMAT(${params.xColumn},'%Y-%m')
        </if>
        <if test = 'params.timeStatType == "年"'>
                SELECT DATE_FORMAT(${params.xColumn},'%Y') ${params.xColumn}, sum(${params.yColumn}) total FROM zhuangxiudingdan
                <where> 1=1 ${ew.sqlSegment}</where>
                group by DATE_FORMAT(${params.xColumn},'%Y')
        </if>
    </select>

    <select id="selectGroup" resultType="map" >
        SELECT ${params.column} , count(1) total FROM zhuangxiudingdan
        <where> 1=1 ${ew.sqlSegment}</where>
        group by ${params.column}
    </select>




</mapper>
